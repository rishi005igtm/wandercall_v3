# ==========================================
# Wandercall Enterprise Backend Environment
# Master Onboarding Template (.env.example)
# NO REAL SECRETS HERE - DUMMY PLACEHOLDERS ONLY
# ==========================================

# --- Application ---
APP_NAME=Wandercall-Backend
APP_ENV=development
PORT=5000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_NAME=wandercall_dev
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redis Cache & Event Bus ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_TLS=false

# --- Apache Kafka Streaming ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=wandercall-backend
KAFKA_GROUP_ID=wandercall-consumer-group
KAFKA_SSL=false
KAFKA_SASL_USER=your_kafka_user
KAFKA_SASL_PASS=your_kafka_pass

# --- JWT Authentication ---
JWT_SECRET=your_jwt_secret_min32chars_required
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min32chars_required
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800
JWT_ISSUER=wandercall-auth-service
JWT_AUDIENCE=wandercall-clients

# --- Cashfree Payment Gateway ---
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_API_VERSION=2022-09-01
CASHFREE_ENV=SANDBOX

# --- Cloud Storage (S3 / CDN) ---
STORAGE_DRIVER=s3
STORAGE_BUCKET=wandercall-dev-assets
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your_storage_access_key
STORAGE_SECRET_KEY=your_storage_secret_key
STORAGE_ENDPOINT=
STORAGE_CDN_URL=https://cdn.example.com

# --- Caching Defaults ---
CACHE_TTL=300
CACHE_MAX_ITEMS=1000

# --- Search Engine (Elasticsearch / Typesense) ---
SEARCH_HOST=http://localhost:9200
SEARCH_API_KEY=your_search_api_key
SEARCH_INDEX_PREFIX=wandercall_dev_

# --- AI Services (OpenAI / LLM) ---
OPENAI_API_KEY=your_openai_api_key
OPENAI_ORG_ID=your_openai_org_id
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT=30000
OPENAI_MAX_RETRIES=3

# --- Mail Server (SMTP) ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_FROM_EMAIL=noreply@wandercall.com
MAIL_FROM_NAME=Wandercall

# --- Push Notifications (FCM / APNS) ---
FCM_SERVER_KEY=your_fcm_server_key
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apns_team_id

# --- Voice & Video (LiveKit) ---
LIVEKIT_HOST=wss://livekit.example.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_WEBHOOK_SECRET=your_livekit_webhook_secret

# --- Security & Rate Limiting ---
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
ENCRYPTION_KEY=your_32_character_encryption_key!

# --- WebSockets / Socket.IO ---
SOCKET_PORT=3001
SOCKET_PATH=/socket.io/
SOCKET_CORS_ORIGIN=*
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=50000

# --- Analytics & Telemetry ---
ANALYTICS_WRITE_KEY=your_analytics_write_key
ANALYTICS_PROVIDER=segment
ANALYTICS_ENABLED=true
