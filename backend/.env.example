# ═══════════════════════════════════════════════════════════════════════════════
# Wandercall Backend — Complete Environment Variable Reference
# Copy this file to .env and fill in real values.
# ⚠️  NEVER commit .env or any file containing real secrets to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=Wandercall-Backend
# Environment: development | staging | production | test
APP_ENV=development
# HTTP port NestJS listens on. Socket.IO shares this same port.
PORT=5000
# Global API prefix (all routes become /api/v1/*)
API_PREFIX=api/v1
# Comma-separated list of allowed CORS origins.
# Production example: https://app.wandercall.com,https://www.wandercall.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# POSTGRESQL — REQUIRED
# ─────────────────────────────────────────────────────────────────────────────
# In Docker/K8s: use the service name (e.g. "postgres"), not "localhost"
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change_me_in_production
DB_NAME=wandercall
# Set to true when connecting to RDS/Cloud SQL with SSL
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─────────────────────────────────────────────────────────────────────────────
# REDIS — provide either REDIS_URL (full connection string) or individual fields
# ─────────────────────────────────────────────────────────────────────────────
# Option A: Full URL (recommended for cloud Redis: upstash, redis cloud, etc.)
# REDIS_URL=rediss://default:password@hostname:6380
# Option B: Individual fields (recommended for self-hosted / Docker compose)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# Upstash REST client (optional, for serverless/edge operations)
# UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─────────────────────────────────────────────────────────────────────────────
# JWT — REQUIRED
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_hex_secret
JWT_REFRESH_SECRET=replace_with_64_char_random_hex_refresh_secret
# Token lifetime in seconds (3600 = 1 hour)
JWT_EXPIRES_IN=3600
# Refresh token lifetime in seconds (604800 = 7 days)
JWT_REFRESH_EXPIRES_IN=604800
JWT_ISSUER=wandercall-auth-service
JWT_AUDIENCE=wandercall-clients

# ─────────────────────────────────────────────────────────────────────────────
# LIVEKIT (Voice & Video) — required for Campfire feature
# ─────────────────────────────────────────────────────────────────────────────
# ws:// for local dev LiveKit server, wss:// for Livekit Cloud
LIVEKIT_HOST=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_WEBHOOK_SECRET=your_livekit_webhook_secret

# ─────────────────────────────────────────────────────────────────────────────
# CLOUDINARY (Image & File Storage) — required for uploads
# Option A: Individual credentials
# ─────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Option B: Full URL (overrides individual credentials if set)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Generic storage fields (used if STORAGE_DRIVER is set to s3 instead of cloudinary)
STORAGE_DRIVER=cloudinary
STORAGE_BUCKET=wandercall-assets
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=
STORAGE_CDN_URL=https://res.cloudinary.com/your_cloud_name

# ─────────────────────────────────────────────────────────────────────────────
# MAIL (SMTP) — required for email verification
# ─────────────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_FROM_EMAIL=noreply@wandercall.com
MAIL_FROM_NAME=Wandercall

# ─────────────────────────────────────────────────────────────────────────────
# AI (OpenAI) — required for social discovery & recommendations
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key
# OPENAI_ORG_ID=org-your_org_id
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT=30000
OPENAI_MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
# 32-byte encryption key for sensitive data at rest
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_32_char_hex_encryption_key_here!

# ─────────────────────────────────────────────────────────────────────────────
# SOCKET.IO — NestJS gateway shares the same HTTP port; these are for config only
# ─────────────────────────────────────────────────────────────────────────────
SOCKET_PATH=/socket.io/
SOCKET_CORS_ORIGIN=*
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=50000

# ─────────────────────────────────────────────────────────────────────────────
# CACHE
# ─────────────────────────────────────────────────────────────────────────────
CACHE_TTL=300
CACHE_MAX_ITEMS=1000

# ─────────────────────────────────────────────────────────────────────────────
# CAMPFIRE LIMITS (all optional, defaults shown)
# ─────────────────────────────────────────────────────────────────────────────
CAMPFIRE_DEFAULT_CAPACITY=50
CAMPFIRE_MAX_CAPACITY=1000
CAMPFIRE_DEFAULT_SPEAKER_LIMIT=10
CAMPFIRE_MAX_SPEAKER_LIMIT=50
CAMPFIRE_DEFAULT_LISTENER_LIMIT=50
CAMPFIRE_CACHE_TTL=3600
CAMPFIRE_PRESENCE_TTL=300

# ─────────────────────────────────────────────────────────────────────────────
# SEARCH ENGINE — optional (Typesense / Elasticsearch)
# ─────────────────────────────────────────────────────────────────────────────
# SEARCH_HOST=http://localhost:9200
# SEARCH_API_KEY=your_search_api_key
# SEARCH_INDEX_PREFIX=wandercall_dev_

# ─────────────────────────────────────────────────────────────────────────────
# KAFKA — optional (not active in current modules)
# ─────────────────────────────────────────────────────────────────────────────
# KAFKA_BROKERS=localhost:9092
# KAFKA_CLIENT_ID=wandercall-backend
# KAFKA_GROUP_ID=wandercall-consumer-group
# KAFKA_SSL=false
# KAFKA_SASL_USER=
# KAFKA_SASL_PASS=

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENT (Cashfree) — optional (payment module scaffolded, not active)
# ─────────────────────────────────────────────────────────────────────────────
# CASHFREE_APP_ID=your_cashfree_app_id
# CASHFREE_SECRET_KEY=your_cashfree_secret_key
# CASHFREE_API_VERSION=2022-09-01
# CASHFREE_ENV=SANDBOX

# ─────────────────────────────────────────────────────────────────────────────
# PUSH NOTIFICATIONS — optional (mobile push not yet active)
# ─────────────────────────────────────────────────────────────────────────────
# FCM_SERVER_KEY=your_fcm_server_key
# APNS_KEY_ID=your_apns_key_id
# APNS_TEAM_ID=your_apns_team_id

# ─────────────────────────────────────────────────────────────────────────────
# ANALYTICS — optional
# ─────────────────────────────────────────────────────────────────────────────
# ANALYTICS_WRITE_KEY=your_segment_write_key
# ANALYTICS_PROVIDER=segment
# ANALYTICS_ENABLED=false
