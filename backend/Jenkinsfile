// ═══════════════════════════════════════════════════════════════════════════════
// Wandercall Enterprise CI/CD Pipeline
// Targets: Local Docker → AWS EC2 → AWS EKS Kubernetes
// ═══════════════════════════════════════════════════════════════════════════════
// groovylint-disable CompileStatic, DuplicateStringLiteral, NestedBlockDepth, LineLength, CouldBeSwitchStatement

pipeline {
    agent any

    environment {
        // App Settings
        APP_NAME = 'wandercall-backend'
        DOCKER_IMAGE = "anmol8733/${APP_NAME}"

        // Dynamic Versioning
        BUILD_TAG = "build-${BUILD_NUMBER}"
        COMMIT_SHA = sh(script: 'git rev-parse --short HEAD || echo "local"', returnStdout: true).trim()

        // Target Environment Abstraction (local, ec2, eks)
        DEPLOY_TARGET = 'local'
    }

    stages {
        stage('Repository Checkout & Validation') {
            steps {
                echo 'Checking out latest code from SCM...'
                checkout scm

                // Fail immediately if critical files are missing
                dir('backend') {
                    sh '''
                    test -f Dockerfile
                    test -f package.json
                    '''
                }
            }
        }

        stage('Dependency & Cache Hydration') {
            steps {
                echo 'Installing dependencies with persistent workspace cache...'
                // Local dev install to allow testing and linting, utilizing workspace cache
                dir('backend') {
                    sh 'npm ci --cache ~/.npm --prefer-offline'
                }
            }
        }

        stage('Security & Code Quality Validation') {
            parallel {
                stage('NPM Audit') {
                    steps {
                        // Scan for vulnerabilities, failing only on High/Critical
                        dir('backend') {
                            sh 'npm audit --audit-level=high || echo "Audit warnings found"'
                        }
                    }
                }
                stage('Linting') {
                    steps {
                        dir('backend') {
                            sh 'npm run lint || echo "Linting warnings"'
                        }
                    }
                }
                stage('Type Check') {
                    steps {
                        dir('backend') {
                            sh 'npx tsc --noEmit'
                        }
                    }
                }
            // stage('Unit Tests') {
            //     steps {
            //         sh 'npm run test'
            //     }
            // }
            }
        }

        stage('Docker Image Build') {
            steps {
                echo "Building Docker Image: ${DOCKER_IMAGE}:${BUILD_TAG}"
                // Enable BuildKit for caching layer mounts
                script {
                    env.DOCKER_BUILDKIT = '1'
                }

                dir('backend') {
                    sh """
                    docker build \\
                        --target production \\
                        -t ${DOCKER_IMAGE}:latest \\
                        -t ${DOCKER_IMAGE}:${BUILD_TAG} \\
                        -t ${DOCKER_IMAGE}:${COMMIT_SHA} \\
                        .
                    """
                }
            }
        }

        stage('Container Security Scan') {
            steps {
                echo 'Scanning Docker Image for vulnerabilities...'
                // Placeholder for Trivy or Docker Scout
                // sh "trivy image --severity HIGH,CRITICAL ${DOCKER_IMAGE}:${BUILD_TAG}"
                echo 'Image scanned successfully.'
            }
        }

        stage('Registry Push') {
            steps {
                echo 'Pushing images to Docker Registry...'
                withDockerRegistry([credentialsId: 'dockerhub-credentials', url: '']) {
                    sh "docker push ${DOCKER_IMAGE}:${BUILD_TAG}"
                    sh "docker push ${DOCKER_IMAGE}:${COMMIT_SHA}"
                    sh "docker push ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('Abstracted Deployment') {
            steps {
                script {
                    if (env.DEPLOY_TARGET == 'local') {
                        echo 'Deploying to Local Docker...'
                        // Stop existing container if running
                        sh 'docker stop wandercall-api-prod || true'
                        sh 'docker rm wandercall-api-prod || true'

                        // Start new container injecting local .env.production
                        sh """
                        docker run -d \\
                            --name wandercall-api-prod \\
                            -p 5000:5000 \\
                            --env-file /opt/wandercall/.env.production \\
                            --restart unless-stopped \\
                            ${DOCKER_IMAGE}:${BUILD_TAG}
                        """
                    }
                    else if (env.DEPLOY_TARGET == 'ec2') {
                        echo 'Deploying to AWS EC2 (Placeholder)...'
                    // SSH into EC2, pull image, run docker-compose up -d
                    }
                    else if (env.DEPLOY_TARGET == 'eks') {
                        echo 'Deploying to AWS EKS (Placeholder)...'
                    // sh "kubectl set image deployment/wandercall-api api=${DOCKER_IMAGE}:${BUILD_TAG} -n production"
                    }
                }
            }
        }

        stage('Health & Smoke Verification') {
            steps {
                echo 'Waiting for container to boot gracefully...'
                sleep time: 10, unit: 'SECONDS'

                script {
                    String targetUrl = 'http://localhost:5000'
                    if (env.DEPLOY_TARGET == 'ec2') {
                        targetUrl = 'http://ec2-placeholder:5000'
                    } else if (env.DEPLOY_TARGET == 'eks') {
                        targetUrl = 'http://api.wandercall.internal'
                    }
                    sh """
                    MAX_RETRIES=5
                    count=0
                    while [ \$count -lt \$MAX_RETRIES ]; do
                        if curl -s ${targetUrl}/api/v1/health/ready | grep '"status":"ok"'; then
                            echo "Health check PASSED for ${env.DEPLOY_TARGET} at ${targetUrl}."
                            exit 0
                        fi
                        count=\$((count+1))
                        echo "Waiting for backend at ${targetUrl}... (\$count/\$MAX_RETRIES)"
                        sleep 5
                    done
                    echo "Health check FAILED for ${env.DEPLOY_TARGET}."
                    exit 1
                    """
                }
            }
        }
    }

    post {
        success {
            echo 'Deployment Pipeline completed successfully.'
        // TODO: Add Slack/Discord webhook notifications
        }
        failure {
            echo 'Deployment Pipeline FAILED.'

            // Automated Rollback Stage if Health Verification Failed
            script {
                if (env.DEPLOY_TARGET == 'local') {
                    echo 'Triggering Auto-Rollback to previous state...'
                // Rollback logic (e.g., redeploying PREVIOUS_TAG) would go here
                }
            }
        }
        always {
            echo 'Cleaning up workspace...'
            cleanWs()
        }
    }
}
